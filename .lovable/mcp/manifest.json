{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "pixelvault-mcp",
      "version": "0.1.0",
      "title": "PixelVault MCP"
    },
    "tools": [
      {
        "name": "search_public_images",
        "title": "Search public images",
        "description": "Search the PixelVault public image library by keyword, title, or description. Returns image metadata including URL, dimensions, and keywords.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "searchText": {
              "default": "",
              "description": "Text to search for. Leave empty to browse recent public images.",
              "type": "string"
            },
            "limit": {
              "default": 12,
              "description": "Maximum number of images to return (1-50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "offset": {
              "default": 0,
              "description": "Pagination offset.",
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_public_image",
        "title": "Get public image by ID",
        "description": "Fetch a single public PixelVault image's metadata by its ID.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "The image ID."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
